{
  "name": "agent-bus",
  "version": "1.0.0",
  "description": "A message bus + task board for teams of agents — over nothing but a shared folder. An open protocol for multi-agent coordination, with a TypeScript reference implementation.",
  "keywords": [
    "agents",
    "multi-agent",
    "coordination",
    "message-bus",
    "task-queue",
    "protocol",
    "ai-agents",
    "orchestration",
    "jsonl"
  ],
  "license": "MIT",
  "author": "agent-bus contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aymandakir-gh/agent-bus.git"
  },
  "homepage": "https://github.com/aymandakir-gh/agent-bus#readme",
  "bugs": {
    "url": "https://github.com/aymandakir-gh/agent-bus/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./schemas/*": "./schemas/*",
    "./package.json": "./package.json"
  },
  "bin": {
    "agent-bus": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "schemas",
    "PROTOCOL.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "examples"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "gen:schemas": "tsx src/scripts/gen-schemas.ts",
    "schemas:bundle": "tsx src/scripts/bundle-schemas.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "2.1.9",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
